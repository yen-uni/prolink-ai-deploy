# ProLink AI 部署環境變數樣本
# 客戶部署精靈 (wizard) 會自動填入,本檔僅供手動部署參考。
# 切勿 commit 真實 secret。

# ── 必填 ─────────────────────────────
WP_DB_PASSWORD=
WP_DB_ROOT_PASSWORD=
UNI_TENANT_ID=

# ── API keys (wizard 步驟 5/6 填) ──
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# ── HMAC (wizard 步驟 7 自動生成) ───
HMAC_SECRET=

# ── DB (wizard 步驟 4 填) ───────────
DB_HOST=
DB_PORT=3306
DB_USER=
DB_PASSWORD=
DB_NAME=

# ── LINE (wizard 步驟 13 填,可選) ──
LINE_CHANNEL_ACCESS_TOKEN=
LINE_CHANNEL_SECRET=
